{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "name": "remark-example",
  "entryPoints": ["./src/index.ts"],
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-remark"],
  "githubPages": false,
  "hidePageHeader": true,
  "mergeReadme": true,
  "router": "module",
  "remarkPlugins": [
    [
      "remark-github",
      { "repository": "https://github.com/typedoc2md/typedoc-plugin-markdown" }
    ],
    ["remark-insert-headings", { "text": "Table of Contents" }],
    ["remark-toc", { "maxDepth": 3 }]
  ],
  "gitRevision": "main"
}
